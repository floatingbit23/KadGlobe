# KadGlobe Configuration Template (LINUX / MacOS)
# Copy this file to .env and fill in your details

# 1. eMule/aMule WebUI Password
ADMIN_PASS='your_password_here'

# 2. Local IP Address (usually 127.0.0.1)
IP_ADDRESS='127.0.0.1'

# 3. eMule/aMule WebUI Port (Default: 4711)
# WEBUI_PORT=4711

# 4. Path to the IP2Location DB (.BIN)
# Default location (handled automatically if commented out)
# IP2LOCATION_DB_PATH='data/IP2LOCATION-LITE-DB5.BIN'

# 5. Kademlia Configuration Files (aMule)
# Note: KadGlobe handles these automatically for aMule if left blank.
# Only set these if using a custom location or Wine/eMule.
EMULE_NODES_DAT_PATH='/home/username/.aMule/nodes.dat'
