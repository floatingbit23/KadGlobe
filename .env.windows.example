# KadGlobe Configuration Template (WINDOWS)
# Copy this file to .env and fill in your details

# 1. eMule WebUI Password (Set in eMule Options -> Web Interface)
ADMIN_PASS='your_password_here'

# 2. Local IP Address (usually 127.0.0.1)
IP_ADDRESS='127.0.0.1'

# 3. Network Ports
# ---------------------------------------------------------
# KadGlobe Web Server Port (Default: 8000)
KADGLOBE_HTTP_PORT=8000

# eMule WebUI Port (Default: 4711)
WEBUI_PORT=4711

# eMule Kademlia UDP Port (Default: 16005)
# Note: Must match your eMule -> Options -> Connection -> UDP
EMULE_KAD_UDP_PORT=16005

# 4. Path to the IP2Location DB (.BIN)
# Default location (handled automatically if commented out)
# IP2LOCATION_DB_PATH='data\\IP2LOCATION-LITE-DB5.BIN'

# 5. Kademlia Configuration Files (eMule)
# Enter the full path to your eMule config directory if you want 
# to use your local routing table as a starting seed.
EMULE_NODES_DAT_PATH='C:\\Program Files (x86)\\eMule\\config\\nodes.dat'

# (Optional) Local Identity: 
# Only needed if you want to force your exact KadID in the Stats UI.
# KadGlobe will try to auto-detect this via UDP if left commented out.
# EMULE_KEY_INDEX_PATH='C:\\Program Files (x86)\\eMule\\config\\key_index.dat'

