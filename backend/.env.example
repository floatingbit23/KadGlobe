# KadGlobe Configuration Template
# Copy this file to .env and fill in your details

# 1. eMule WebUI Password (Set in eMule Options -> Web Interface)
ADMIN_PASS='your_password_here'

# 2. Local IP Address (usually 127.0.0.1)
IP_ADDRESS='127.0.0.1'

# 3. Path to the IP2Location DB (.BIN)
# You can download the LITE-DB5 from: https://lite.ip2location.com/ (free, average size: 68MB)
IP2LOCATION_DB_PATH='../data/IP2LOCATION-LITE-DB5.BIN'

# 4. Kademlia Configuration Files

# Windows (Default): 'C:\\Program Files (x86)\\eMule\\config\\...'
# Linux (aMule): '/home/username/.aMule/...'
# Note: KadGlobe handles Linux/aMule path detection automatically if not set here.

EMULE_NODES_DAT_PATH='C:\\Program Files (x86)\\eMule\\config\\nodes.dat'
EMULE_KEY_INDEX_PATH='C:\\Program Files (x86)\\eMule\\config\\key_index.dat'
